{
  "id": "my-love",
  "title": "My Love",
  "artist": "Westlife",
  "lyrics": [
    {
      "text": "An empty street, an empty house",
      "char_delay": 0.09,
      "line_pause": 0.5
    },
    {
      "text": "A hole inside my heart",
      "char_delay": 0.09,
      "line_pause": 0.5
    },
    {
      "text": "I'm all alone, the rooms are getting smaller",
      "char_delay": 0.07,
      "line_pause": 1.2
    },
    {
      "text": "",
      "char_delay": 0,
      "line_pause": 0.5
    },
    {
      "text": "I wonder how, I wonder why",
      "char_delay": 0.1,
      "line_pause": 0.5
    },
    {
      "text": "I wonder where they are",
      "char_delay": 0.1,
      "line_pause": 0.5
    },
    {
      "text": "The days we had, the songs we sang together",
      "char_delay": 0.07,
      "line_pause": 1
    },
    {
      "text": "Oh, yeah...",
      "char_delay": 0.15,
      "line_pause": 1.2
    },
    {
      "text": "",
      "char_delay": 0,
      "line_pause": 0.5
    },
    {
      "text": "And all my love, I'm holding on forever",
      "char_delay": 0.08,
      "line_pause": 0.6
    },
    {
      "text": "Reaching for the love that seems so far",
      "char_delay": 0.08,
      "line_pause": 1.5
    }
  ]
